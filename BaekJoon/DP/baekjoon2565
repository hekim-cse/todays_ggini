import sys
input = sys.stdin.readline

n = int(input())
lines = [list(map(int, input().split())) for _ in range(n)]

lines.sort()

# B 전봇대 위치만 따로 모음
b_positions = [x[1] for x in lines]

# LIS(최장 증가 부분 수열) 길이 구하기 (DP)
dp = [1] * n
for i in range(n):
    for j in range(i):
        if b_positions[j] < b_positions[i]:
            dp[i] = max(dp[i], dp[j] + 1)

# 4. 결과 출력: 전체 개수 - 최대 보존 가능 개수
print(n - max(dp))


